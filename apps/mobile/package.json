{
  "name": "@budget/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:update": "cross-env EAS_NO_VCS=1 eas update --branch production",
    "eas:build:apk": "node scripts/run-eas-android-apk.cjs",

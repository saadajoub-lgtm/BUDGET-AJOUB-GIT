    "eas:build:production": "cross-env EAS_NO_VCS=1 eas build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/native": "^7.2.4",
    "expo": "^53.0.0",
    "expo-dev-client": "~5.2.4",
    "expo-updates": "^0.28.18",
    "firebase": "^12.4.0",
    "fs-extra": "^11.3.5",
    "react": "^19.0.0",
    "react-native": "^0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eas-cli": "^16.28.0",
    "typescript": "~5.8.3"
